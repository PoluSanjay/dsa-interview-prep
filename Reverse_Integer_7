class Solution:
    def reverse(self, x):
        if x < 0:
            sign = -1
        else:
            sign = 1

        x = abs(x)
        rev = 0

        while x != 0:
            d = x % 10

            # overflow check using direct value
            if rev > 214748364:
                return 0

            rev = rev * 10 + d
            x = x // 10

        rev = rev * sign

        if rev < -2147483648 or rev > 2147483647:
            return 0

        return rev
