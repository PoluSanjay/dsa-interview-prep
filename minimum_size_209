class Solution:
    def minSubArrayLen(self, target: int, nums: List[int]) -> int:
        l=0
        s=0
        mini=float('inf')
        for r in range(len(nums)):
            s=s+nums[r]
            while s>=target:
                s=s-nums[l]
                mini=min(mini,r-l+1)
                l+=1
        if mini==float('inf'):return 0
        else:return mini
        
